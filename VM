# Create a Service Account for the VMs (Security Best Practice)
resource "google_service_account" "web_sa" {
  account_id   = "ent-prod-web-sa"
  
}

# The Virtual Machine Instances
resource "google_compute_instance" "web_servers" {
  count        = 2
  name         = "ent-prod-web-vm-${count.index + 1}"
  machine_type = "e2-micro"
  zone         = "us-central1-a"

  boot_disk {
    initialize_params {
      image = "debian-cloud/debian-11"
    }
  }

  network_interface {
    network    = google_compute_network.vpc_network.id
    subnetwork = google_compute_subnetwork.private_subnet.id
  }

  # Automatic Nginx Installation
  metadata_startup_script = <<-EOT
    #! /bin/bash
    apt-get update
    apt-get install -y nginx
    echo "<h1>Hello from Web Server ${count.index + 1}</h1>" > /var/www/html/index.html
  EOT

  service_account {
    email  = google_service_account.web_sa.email
    scopes = ["cloud-platform"]
  }
}
