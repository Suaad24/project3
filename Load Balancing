# 1. Health Check
resource "google_compute_health_check" "http_hc" {
  name = "http-health-check"
  http_health_check {
    port = 80
  }
}

# 2. Backend Service
resource "google_compute_backend_service" "web_backend" {
  name                  = "web-backend-service"
  protocol              = "HTTP"
  load_balancing_scheme = "EXTERNAL_MANAGED"
  health_checks         = [google_compute_health_check.http_hc.id]
  
  backend {
    group = google_compute_instance_group.web_ig.id # Assuming you created this
  }
}

# 3. URL Map (The "Brain" of the LB)
resource "google_compute_url_map" "web_map" {
  name            = "ent-prod-web-lb"
  default_service = google_compute_backend_service.web_backend.id
}

# 4. HTTP Proxy
resource "google_compute_target_http_proxy" "http_proxy" {
  name    = "web-http-proxy"
  url_map = google_compute_url_map.web_map.id
}

# 5. Global Forwarding Rule (The Public IP)
resource "google_compute_global_forwarding_rule" "forwarding_rule" {
  name                  = "web-forwarding-rule"
  ip_protocol           = "TCP"
  load_balancing_scheme = "EXTERNAL_MANAGED"
  port_range            = "80"
  target                = google_compute_target_http_proxy.http_proxy.id
}
